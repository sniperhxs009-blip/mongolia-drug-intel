# 蒙古国涉毒情报系统 - 环境变量配置模板
# 复制此文件为 .env 并填入真实值，.env 不会被提交到 Git

# DeepSeek API Key（AI 智能分类）
DEEPSEEK_API_KEY=sk-your-key-here

# 管理后台鉴权 Token（采集/停止接口需要）
ADMIN_TOKEN=your-admin-token-here

# 日志级别: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# 服务端口（Render 自动设置）
PORT=8000

# 接口限流：每 IP 每分钟最大请求数
RATE_LIMIT_PER_MINUTE=60
